{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "bio": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "job_title": {
      "type": "string"
    },
    "profile_photo": {
      "type": "string"
    },
    "ai_provider": {
      "type": "string",
      "enum": [
        "none",
        "grok",
        "claude"
      ],
      "default": "none"
    },
    "ai_api_key": {
      "type": "string"
    }
  }
}