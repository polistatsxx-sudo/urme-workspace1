{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "bio": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "job_title": {
      "type": "string"
    },
    "profile_photo": {
      "type": "string"
    },
    "ai_provider": {
      "type": "string",
      "enum": [
        "none",
        "grok",
        "claude"
      ],
      "default": "none"
    },
    "ai_api_key": {
      "type": "string"
    },
    "display_name": {
      "type": "string",
      "description": "Editable display name"
    },
    "linkedin": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "on_leave"
      ],
      "default": "active"
    },
    "joined_date": {
      "type": "string",
      "format": "date"
    },
    "subscription_status": {
      "type": "string",
      "enum": [
        "active",
        "expired",
        "none"
      ],
      "default": "none",
      "description": "Subscription status"
    },
    "paid_through_date": {
      "type": "string",
      "format": "date",
      "description": "Date until which access is granted (from upfront payment or active subscription)"
    },
    "stripe_customer_id": {
      "type": "string",
      "description": "Optional Stripe customer ID for future webhook integration"
    }
  }
}